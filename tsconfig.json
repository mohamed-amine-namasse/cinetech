{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./",
    "rootDir": "./",
    "noEmitOnError": false
  },
  "include": ["index.ts", "globals.d.ts"],
  "exclude": ["node_modules"]
}
